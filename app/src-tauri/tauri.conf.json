{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VeloOverlay",
  "version": "0.1.0",
  "identifier": "com.velooverlay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace=app",
    "beforeBuildCommand": "npm run build --workspace=app"
  },
  "app": {
    "windows": [
      {
        "title": "VeloOverlay",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
